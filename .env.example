# .env.example — copy to .env and fill in your real values.
# NEVER commit .env itself (it's in .gitignore).
#
# Settings resolution order (locked Q22):
#   1. CLI flags               (--site, --email, --api-token, --debug, --config=…, --listen=…)
#   2. Process environment    (the ATLASSIAN_* vars below + DEBUG)
#   3. .env in cwd             (this file)
#   4. .env next to the binary (resolved from os.Executable())
#
# Generate your Atlassian API token at:
# https://id.atlassian.com/manage-profile/security/api-tokens

# === Required: Atlassian Cloud credentials =================================
ATLASSIAN_SITE_NAME=your-company
ATLASSIAN_USER_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=ATATT3xFfGF0...

# === Optional: --debug flag equivalent ====================================
# Set to "true" to make the binary log every tool call to stderr.
# Matches the --debug CLI flag.
DEBUG=false

# === Optional: --listen flag equivalent (serve subcommand only) ===========
# The serve subcommand binds this host:port. Default 127.0.0.1:8080.
# Set to 0.0.0.0:8080 ONLY behind a trusted reverse proxy.
# ATLASSIAN_LISTEN=127.0.0.1:8080

# === Optional: --config flag equivalent ====================================
# Path to a viper-compatible config file (YAML/JSON/TOML/INI/envfile).
# CLI flag form: mcp-confluence stdio --config=/path/to/confluence.yaml
# ATLASSIAN_CONFIG=/path/to/confluence.yaml

# NEVER log or store the token in plaintext. The startup banner prints
# 'Note: API token value not logged for security' on every run. `make
# verify-env` displays only the token's length, not its value.
